# --- python --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- venv ----------------------------------------------------------------
.venv/
venv/
env/

# --- experiment outputs --------------------------------------------------
# Study repo: figures / logs / checkpoints are committed so results are
# browsable on GitHub. Only the regenerable bulk-binary artifacts
# (datasets, raw arrays) stay ignored.
outputs/datasets/*
!outputs/datasets/.gitkeep

reaction_diffusion_peb/outputs/datasets/*
!reaction_diffusion_peb/outputs/datasets/.gitkeep
reaction_diffusion_peb/outputs/arrays/*
!reaction_diffusion_peb/outputs/arrays/.gitkeep

# --- editor / OS ---------------------------------------------------------
.vscode/
.idea/
.DS_Store

# --- claude --------------------------------------------------------------
.claude/settings.local.json
